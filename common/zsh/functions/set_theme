# set_theme - unified theme switcher for Ghostty, WezTerm, and Zellij
# Updates .dotter/global.toml and re-renders all templated configs via dotter
set_theme() {
    local theme="$1"

    typeset -A ghostty_themes=(
        tokyo-night          "Tokyo Night"
        catppuccin-macchiato "Catppuccin Macchiato"
        catppuccin-mocha     "Catppuccin Mocha"
        gruvbox-dark         "GruvboxDark"
    )
    typeset -A wezterm_themes=(
        tokyo-night          "Tokyo Night Storm (Gogh)"
        catppuccin-macchiato "Catppuccin Macchiato (Gogh)"
        catppuccin-mocha     "Catppuccin Mocha (Gogh)"
        gruvbox-dark         "GruvboxDark"
    )
    typeset -A zellij_themes=(
        tokyo-night          "tokyo-night"
        catppuccin-macchiato "catppuccin-macchiato"
        catppuccin-mocha     "catppuccin-mocha"
        gruvbox-dark         "gruvbox-dark"
    )

    if [[ -z "$theme" ]] || [[ -z "${ghostty_themes[$theme]}" ]]; then
        echo "Usage: set_theme <theme>"
        echo "Valid themes: ${(k)ghostty_themes}"
        return 1
    fi

    # Locate dotfiles via the dotter symlink for zellij — portable across macOS/WSL
    local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/zellij"
    local dotfiles="${config_dir:A:h:h}"
    local global_toml="$dotfiles/.dotter/global.toml"

    if [[ ! -f "$global_toml" ]]; then
        echo "set_theme: cannot find $global_toml" >&2
        return 1
    fi

    python3 - "$global_toml" "$theme" "${ghostty_themes[$theme]}" "${wezterm_themes[$theme]}" "${zellij_themes[$theme]}" <<'EOF'
import sys, re

toml_path, theme, g_theme, w_theme, z_theme = sys.argv[1:]

with open(toml_path) as f:
    content = f.read()

def replace_var(text, key, value):
    return re.sub(
        rf'^({re.escape(key)}\s*=\s*).*$',
        lambda m: f'{m.group(1)}"{value}"',
        text,
        flags=re.MULTILINE
    )

content = replace_var(content, 'theme',         theme)
content = replace_var(content, 'theme_ghostty', g_theme)
content = replace_var(content, 'theme_wezterm', w_theme)
content = replace_var(content, 'theme_zellij',  z_theme)

with open(toml_path, 'w') as f:
    f.write(content)
EOF

    echo "Theme set to '$theme' — running dotter..."
    (cd "$dotfiles" && dotter)
}

set_theme
