# Normalize line endings to LF in the repo
* text=auto eol=lf

# Shell scripts must always be LF
*.sh    text eol=lf
*.zsh   text eol=lf
*.bash  text eol=lf
*.zshrc text eol=lf
*.zshenv text eol=lf

# Config files
*.toml  text eol=lf
*.kdl   text eol=lf
*.lua   text eol=lf

# Windows-specific files keep CRLF
*.ps1   text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ahk   text eol=crlf
